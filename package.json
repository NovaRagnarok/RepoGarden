{
  "name": "@outsideheaven/repogarden",
  "version": "0.9.3",
  "private": false,
  "license": "MIT",
  "author": {
    "name": "Outsideheaven",
    "url": "https://github.com/NovaRagnarok"
  },
  "description": "A little local habitat where your repos live.",
  "keywords": [
    "tui",
    "ink",
    "git",
    "developer-tools",
    "local-first",
    "repogarden"
  ],
  "homepage": "https://github.com/NovaRagnarok/RepoGarden#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NovaRagnarok/RepoGarden.git"
  },
  "bugs": {
    "url": "https://github.com/NovaRagnarok/RepoGarden/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/NovaRagnarok"
    },
    {
      "type": "ko-fi",
      "url": "https://ko-fi.com/outsideheaven"
    }
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "bin": {
    "repogarden": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm run clean && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json -f",
    "prepare": "pnpm run build",
    "prepack": "pnpm run build",
    "start": "node dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test --test-concurrency=1 src/__tests__/*.test.ts src/__tests__/*.test.tsx",
    "observe:tui": "./scripts/tui-observe.sh",
    "gen:site-creatures": "tsx scripts/gen-site-creatures.ts"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-spinners": "^3.4.0",
    "gifenc": "^1.0.3",
    "ink": "^7.0.3",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
